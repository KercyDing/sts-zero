!label false

% Debug Build
b():
    rm -rf zig-out
    zig build
    echo 'Done.'

% Debug Run
r():
    zig build run

% Build Metal+Vulkan Shader
s(name):
    ./tools/impellerc-linux-x64 --runtime-stage-metal --runtime-stage-vulkan --input=src/assets/shaders/{{name}}.frag --input-type=frag --sl=src/assets/shaders/{{name}}.iplr --spirv=/tmp/sts-zero-{{name}}.spv --iplr --verbose
    echo 'Done.'

% Test
t():
    zig build test
    echo 'Done.'

% Format
f():
    zig fmt src
    echo 'Done.'

% Clean Cache, Output
c():
    rm -rf .zig-cache zig-out
    echo 'Done.'

% Publish Release
p():
    rm -rf zig-out
    zig build run -Doptimize=ReleaseSafe -Dstrip=true
